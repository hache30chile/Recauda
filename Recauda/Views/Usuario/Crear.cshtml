@model Usuario

@{
    ViewData["Title"] = "Crear Nuevo Usuario";
    int rolTesoreroId = ViewBag.RolTesoreroId ?? 0;
}

<h1 class="mt-4">@ViewData["Title"]</h1>
<ol class="breadcrumb mb-4">
    <li class="breadcrumb-item"><a asp-controller="Home" asp-action="Index">Dashboard</a></li>
    <li class="breadcrumb-item"><a asp-action="Index">Usuarios</a></li>
    <li class="breadcrumb-item active">Crear</li>
</ol>

@if (TempData["ErrorMessage"] != null)
{
    <div class="alert alert-danger alert-dismissible fade show" role="alert">
        <i class="fas fa-exclamation-circle"></i>
        @TempData["ErrorMessage"]
        <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
    </div>
}

<div class="row">
    <div class="col-lg-8">
        <div class="card">
            <div class="card-header">
                <i class="fas fa-user-plus me-1"></i>
                Información del Nuevo Usuario
            </div>
            <div class="card-body">
                @if (!ViewData.ModelState.IsValid)
                {
                    <div class="alert alert-warning">
                        <h6>Errores de validación:</h6>
                        <ul>
                            @foreach (var error in ViewData.ModelState.Values.SelectMany(v => v.Errors))
                            {
                                <li>@error.ErrorMessage</li>
                            }
                        </ul>
                    </div>
                }

                <form asp-controller="Usuario" asp-action="Crear" method="post">
                    @Html.AntiForgeryToken()

                    <div class="row">
                        <div class="col-md-6 mb-3">
                            <label asp-for="Login" class="form-label">
                                <i class="fas fa-user"></i> Login de Usuario *
                            </label>
                            <input asp-for="Login" class="form-control" placeholder="Ej: juanperez" />
                            <span asp-validation-for="Login" class="text-danger"></span>
                        </div>
                        <div class="col-md-6 mb-3">
                            <label asp-for="Nombre" class="form-label">
                                <i class="fas fa-id-card"></i> Nombre Completo *
                            </label>
                            <input asp-for="Nombre" class="form-control" placeholder="Ej: Juan Pérez González" />
                            <span asp-validation-for="Nombre" class="text-danger"></span>
                        </div>
                    </div>

                    <div class="row">
                        <div class="col-md-4 mb-3">
                            <label asp-for="Rut" class="form-label">
                                <i class="fas fa-id-badge"></i> RUT *
                            </label>
                            <input asp-for="Rut" class="form-control" placeholder="12345678" type="number" />
                            <span asp-validation-for="Rut" class="text-danger"></span>
                        </div>
                        <div class="col-md-2 mb-3">
                            <label asp-for="Dv" class="form-label">
                                <i class="fas fa-check"></i> DV *
                            </label>
                            <input asp-for="Dv" class="form-control" placeholder="5" maxlength="1" />
                            <span asp-validation-for="Dv" class="text-danger"></span>
                        </div>
                        <div class="col-md-6 mb-3">
                            <label asp-for="RolId" class="form-label">
                                <i class="fas fa-user-tag"></i> Rol *
                            </label>
                            <select asp-for="RolId" asp-items="ViewBag.Roles" class="form-select" id="rolSelect">
                                <option value="">-- Seleccione un Rol --</option>
                            </select>
                            <span asp-validation-for="RolId" class="text-danger"></span>
                        </div>
                    </div>

                    <div class="row">
                        <div class="col-md-6 mb-3">
                            <label asp-for="Clave" class="form-label">
                                <i class="fas fa-lock"></i> Contraseña *
                            </label>
                            <input asp-for="Clave" type="password" class="form-control" placeholder="Mínimo 6 caracteres" />
                            <span asp-validation-for="Clave" class="text-danger"></span>
                        </div>
                        <div class="col-md-6 mb-3">
                            <div class="form-check form-switch mt-4">
                                <input asp-for="Activo" class="form-check-input" type="checkbox" checked />
                                <label asp-for="Activo" class="form-check-label">
                                    <i class="fas fa-toggle-on"></i> Usuario Activo
                                </label>
                            </div>
                            <small class="form-text text-muted">
                                Los usuarios inactivos no podrán acceder al sistema.
                            </small>
                        </div>
                    </div>

                  
                    <div class="row" id="seccionTesorero" style="display:none !important;">
                        <div class="col-12 mb-3">
                            <div class="card border-warning">
                                <div class="card-header bg-warning text-dark">
                                   Asignación de Compañía — Tesorero
                                </div>
                                <div class="card-body">
                                    <p class="text-muted small mb-2">
                                        El rol de <strong>Tesorero</strong> requiere asociar al usuario a una compañía.
                                        Solo puede existir <strong>un Tesorero por compañía</strong>.
                                    </p>
                                    <label for="companiaId" class="form-label">
                                        <i class="fas fa-building"></i> Compañía *
                                    </label>
                                    <select name="companiaId" id="companiaId" class="form-select">
                                        <option value="">-- Seleccione una Compañía --</option>
                                        @foreach (var item in (IEnumerable<Microsoft.AspNetCore.Mvc.Rendering.SelectListItem>)ViewBag.Companias)
                                        {
                                            if (item.Value == ViewBag.CompaniaSeleccionada?.ToString())
                                            {
                                                <option value="@item.Value" selected>@item.Text</option>
                                            }
                                            else
                                            {
                                                <option value="@item.Value">@item.Text</option>
                                            }
                                        }
                                    </select>
                                    <div id="avisoTesorero" class="alert alert-danger mt-2" style="display:none;">
                                        <i class="fas fa-exclamation-triangle"></i>
                                        <span id="avisoTesoreroTexto"></span>
                                    </div>
                                </div>
                            </div>
                        </div>
                    </div>

                   
                    <div class="row" id="seccionGenerador">
                        <div class="col-12 mb-3">
                            <div class="card border-info">
                                <div class="card-header bg-info text-white">
                                    <i class="fas fa-bolt"></i> Configuración de Generador
                                </div>
                                <div class="card-body">
                                    <div class="form-check form-switch">
                                        <input name="esGenerador" class="form-check-input" type="checkbox"
                                               id="esGenerador" value="true" />
                                        <label class="form-check-label" for="esGenerador">
                                            <i class="fas fa-industry"></i> Este usuario es un generador
                                        </label>
                                    </div>
                                    <small class="form-text text-muted">
                                        Los usuarios generadores tienen permisos especiales para crear y gestionar cobros.
                                    </small>
                                </div>
                            </div>
                        </div>
                    </div>

                    <div class="row mt-4">
                        <div class="col-12">
                            <button type="submit" class="btn btn-success" id="btnGuardar">
                                <i class="fas fa-save"></i> Crear Usuario
                            </button>
                            <a asp-action="Index" class="btn btn-secondary ms-2">
                                <i class="fas fa-arrow-left"></i> Cancelar
                            </a>
                        </div>
                    </div>
                </form>
            </div>
        </div>
    </div>

    <div class="col-lg-4">
        <div class="card">
            <div class="card-header">
                <i class="fas fa-info-circle me-1"></i>
                Información Importante
            </div>
            <div class="card-body">
                <h6 class="card-title">Consejos para crear usuarios:</h6>
                <ul class="card-text">
                    <li>Use logins únicos y descriptivos</li>
                    <li>Verifique que el RUT sea correcto</li>
                    <li>Asigne el rol apropiado al usuario</li>
                    <li>Use contraseñas seguras</li>
                    <li>Configure como generador solo si es necesario</li>
                </ul>

                <div class="mt-3">
                    <h6 class="card-title">Rol Tesorero:</h6>
                    <p class="text-muted small">
                        Solo puede haber <strong>un Tesorero por compañía</strong>.
                        Al asignar este rol, se asociará el usuario a la compañía seleccionada.
                    </p>
                </div>

                <div class="mt-3">
                    <h6 class="card-title">¿Qué es un Generador?</h6>
                    <p class="text-muted small">
                        Un generador es un usuario con permisos especiales para crear y gestionar cobros en el sistema.
                    </p>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }

    <script>
        const ROL_TESORERO_ID = @rolTesoreroId;

        document.addEventListener('DOMContentLoaded', function () {

            const rolSelect       = document.getElementById('rolSelect');
            const seccionTesorero = document.getElementById('seccionTesorero');
            const seccionGenerador= document.getElementById('seccionGenerador');
            const companiaSelect  = document.getElementById('companiaId');
            const avisoDiv        = document.getElementById('avisoTesorero');
            const avisoTexto      = document.getElementById('avisoTesoreroTexto');
            const btnGuardar      = document.getElementById('btnGuardar');

            // ── Mostrar/ocultar sección Tesorero según rol elegido ──
            function actualizarSeccionTesorero() {
                const esTesorero = parseInt(rolSelect.value) === ROL_TESORERO_ID;

                if (esTesorero) {
                    seccionTesorero.style.removeProperty('display');
                    seccionGenerador.style.removeProperty('display');
                } else {
                    seccionTesorero.style.display = 'none';
                    seccionGenerador.style.removeProperty('display');
                    companiaSelect.value = '';
                    ocultarAviso();
                }
            }

            // ── Verificar via AJAX si la compañía ya tiene Tesorero ──
            async function verificarTesorero(companiaId) {
                if (!companiaId) { ocultarAviso(); return; }

                try {
                    const resp = await fetch(`/Usuario/VerificarTesorero?companiaId=${companiaId}`);
                    const data = await resp.json();

                    if (data.tieneTes) {
                        mostrarAviso(data.mensaje);
                        btnGuardar.disabled = true;
                    } else {
                        ocultarAviso();
                        btnGuardar.disabled = false;
                    }
                } catch {
                    ocultarAviso();
                }
            }

            function mostrarAviso(texto) {
                avisoTexto.textContent = texto;
                avisoDiv.style.display = '';
            }

            function ocultarAviso() {
                avisoDiv.style.display = 'none';
                avisoTexto.textContent = '';
                btnGuardar.disabled = false;
            }

            // ── Eventos ──
            rolSelect.addEventListener('change', actualizarSeccionTesorero);
            companiaSelect.addEventListener('change', function () {
                verificarTesorero(this.value);
            });

            // Inicializar al cargar (por si hay errores de validación y se recarga el form)
            actualizarSeccionTesorero();
            if (companiaSelect.value) verificarTesorero(companiaSelect.value);

            // ── Formateo RUT ──
            const rutInput = document.querySelector('input[name="Rut"]');
            if (rutInput) {
                rutInput.addEventListener('input', function (e) {
                    e.target.value = e.target.value.replace(/\D/g, '');
                });
            }

            const dvInput = document.querySelector('input[name="Dv"]');
            if (dvInput) {
                dvInput.addEventListener('input', function (e) {
                    let v = e.target.value.toUpperCase();
                    if (!/^[0-9K]$/.test(v)) e.target.value = v.slice(0, -1);
                });
            }
        });
    </script>
}
